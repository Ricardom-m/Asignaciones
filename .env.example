# ─────────────────────────────────────────────────────────────
#  Asignaciones — variables de entorno
#  Copia este archivo a `.env` y rellena los valores reales.
#  NUNCA subas `.env` al repo (ya está en .gitignore).
# ─────────────────────────────────────────────────────────────

# PostgreSQL — Neon (console.neon.tech → Connect → connection string)
# DATABASE_URL: usa la cadena CON "-pooler" (runtime).
# DIRECT_URL:   la misma cadena pero SIN "-pooler" (la usan las migraciones).
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# Auth.js — genera un secreto con:  npx auth secret   (o:  openssl rand -base64 32)
AUTH_SECRET="reemplaza-con-un-secreto-largo-y-aleatorio"

# URL pública de la app. En local puede omitirse (usa http://localhost:3000).
# En Railway: la URL del dominio, p.ej. https://asignaciones.up.railway.app
AUTH_URL="http://localhost:3000"

# Credenciales OAuth de Google (Google Cloud Console → Credenciales → OAuth 2.0 Web app)
# Redirect URI autorizado:  {AUTH_URL}/api/auth/callback/google
AUTH_GOOGLE_ID="tu-client-id.apps.googleusercontent.com"
AUTH_GOOGLE_SECRET="tu-client-secret"

# Lista blanca de correos que PUEDEN entrar (separados por coma). El resto se rechaza.
AUTHORIZED_EMAILS="tucorreo@gmail.com,companero@gmail.com"
