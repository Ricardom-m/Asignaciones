// Asignaciones v2 — esquema de base de datos
// Datos COMPARTIDOS por todo el equipo: no hay userId en los registros.
// El control de acceso es por allowlist de correos en Auth.js (ver src/lib/auth.ts),
// con sesiones JWT, por lo que no se necesitan tablas de usuarios aquí.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL") // conexión con pooler (runtime)
  directUrl = env("DIRECT_URL")   // conexión directa, sin pooler (migraciones)
}

model Role {
  id        String   @id @default(cuid())
  nombre    String   @unique
  color     String   @default("#4f8ef7") // color del distintivo/badge
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  persons Person[] @relation("PersonRoles")
}

// Sección de la reunión (Tesoros de la Biblia, Seamos mejores maestros, …).
// Editable desde la app; un registro puede pertenecer a una sección.
model Section {
  id          String   @id @default(cuid())
  nombre      String   @unique
  orden       Int      @default(0) // orden de aparición en los selects
  active      Boolean  @default(true)
  sinAyudante Boolean  @default(false) // true = la parte es de una sola persona (sin ayudante)
  unaPorSala  Boolean  @default(false) // true = máximo una parte por sala (p. ej. Lectura de la Biblia)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  records Record[]
}

enum Genero {
  H // Hombre
  M // Mujer
}

enum RecordTipo {
  ASIGNACION // asignación normal (con/sin ayudante)
  NOMBRADO // asignación de un nombrado (sin ayudante)
}

model Person {
  id        String   @id @default(cuid())
  nombre    String
  apellido  String
  genero    Genero? // para la compatibilidad de pareja en las sugerencias
  active    Boolean  @default(true) // desactivar = ocultar sin borrar (soft-delete)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Una persona puede tener varios roles (muchos-a-muchos).
  roles Role[] @relation("PersonRoles")

  // Una persona puede aparecer como asignado principal o como ayudante.
  asignadoRecords Record[] @relation("Asignado")
  ayudanteRecords Record[] @relation("Ayudante")

  @@index([nombre, apellido])
}

// Correos autorizados a iniciar sesión (allowlist gestionable desde la app).
// AUTHORIZED_EMAILS (env) sigue funcionando como respaldo "permanente".
model AllowedUser {
  id        String   @id @default(cuid())
  email     String   @unique
  nombre    String?
  createdAt DateTime @default(now())
}

model Meeting {
  id        String   @id @default(cuid())
  fecha     DateTime @unique @db.Date // una reunión por fecha
  nota      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([fecha])
}

// Configuración (regla) para generar reuniones. Fila única.
model MeetingConfig {
  id          String    @id @default("default")
  weekdays    Int[]     @default([4, 6]) // 0=Dom … 6=Sáb
  weeks       Int       @default(4)
  lastEnsured DateTime? // última vez que se auto-rellenó la ventana
  updatedAt   DateTime  @updatedAt
}

model Record {
  id         String  @id @default(cuid())
  asignadoId String
  asignado   Person  @relation("Asignado", fields: [asignadoId], references: [id])
  ayudanteId String?
  ayudante   Person? @relation("Ayudante", fields: [ayudanteId], references: [id], onDelete: SetNull)

  fecha      DateTime   @db.Date // fecha de la asignación (solo día)
  sala       String?
  asignacion String
  minutos    Int? // duración en minutos (p. ej. Lectura de la Biblia = 4)
  orden      Int        @default(0) // posición dentro de su grupo (fecha+sección+sala) en el planificador
  tipo       RecordTipo @default(ASIGNACION)

  // Sección de la reunión (opcional). Si se borra la sección, queda en null.
  sectionId String?
  section   Section? @relation(fields: [sectionId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([fecha])
  @@index([fecha, id]) // orden + cursor pagination estable
  @@index([tipo, fecha]) // filtrar por tipo + orden por fecha
  @@index([asignadoId])
  @@index([ayudanteId])
  @@index([sectionId])
  @@index([createdAt])
}
